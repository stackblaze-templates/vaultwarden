# Vaultwarden environment configuration
# Copy this file to .env and fill in the values before running locally.
# NEVER commit the .env file — it is excluded by .gitignore.

# -----------------------------------------------------------------------
# REQUIRED — must be set before running in production
# -----------------------------------------------------------------------

# Admin panel token — use a strong random value
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN_openssl_rand_base64_48

# -----------------------------------------------------------------------
# OPTIONAL — recommended for production hardening
# -----------------------------------------------------------------------

# PostgreSQL connection string (leave unset to use the default SQLite DB)
# DATABASE_URL=postgresql://vaultwarden:password@db:5432/vaultwarden

# Allow registration during initial setup; set to false after your first account is created
SIGNUPS_ALLOWED=true

# Set to true in production when behind a TLS-terminating reverse proxy (HTTPS)
COOKIE_SECURE=false

# Domain used in invitation links and HSTS headers
# DOMAIN=https://vault.example.com
